# ##########################################
# Configuration for Node.js, Windows, macOS, and Linux
# ##########################################

# === Node.js ===
# Dependency directories
node_modules/
jspm_packages/
web_modules/

# Debug and Log files
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Diagnostic reports (next.js / node)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented code coverage downloads
lib-cov
coverage
*.lcov

# Serverless Webpack directories
.webpack/

# Bundler / Build outputs
dist/
dist-ssr/
build/
out/
.cache/
.parcel-cache/
.next/
.nuxt/
.svelte-kit/
.expo/
public/hot

# TypeScript Cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn / Pnpm specific files
.yarn-integrity
.yarn/install-state.gz
.pnpm-store/

# Local env files / Secrets (Never commit secrets to git!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env.local

# === Editor / IDE ===
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# === macOS ===
.DS_Store
.AppleDouble
.LSOverride

# Icon must end with two \r characters
Icon?

# Thumbnails
._*

# Files that might be created by the Finder/System
.DocumentRevisions-V100
.Spotlight-V100
.Trashes
.VolumeIcon.icns
.fseventsd

# === Windows ===
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# === Linux ===
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*
